# GSSG Manager — TLS terminator in front of uvicorn (Phase 5, LIVE config).
#
# Caddy owns :443 (and :80 → :443 redirect) on the LAN and reverse-proxies to
# uvicorn on 127.0.0.1:8765. Same-origin, so no CORS changes needed.
#
# Run (as a Windows service via scripts/install-caddy-service.ps1):
#   caddy run --config deploy/Caddyfile
#
# Access from LAN devices:  https://gssg.lan/
#   * DNS: add a UniFi "Local DNS record"  gssg.lan -> 192.168.15.102
#   * Cert: Caddy's internal CA signs the cert. Install/trust the root CA once
#     per device — export it with:  scripts/export-caddy-ca.ps1
#
# ─────────────────────────────────────────────────────────────────────────────
{
	# Persist the internal CA + issued certs in a fixed, exportable location so
	# the root CA can be distributed to LAN devices (phones/PCs trust it once).
	storage file_system {
		root C:/Tools/caddy/data
	}
}

# LAN HTTPS via Caddy's internal CA. uvicorn stays on loopback:8765.
https://gssg.lan {
	tls internal
	reverse_proxy 127.0.0.1:8765
}

# ─────────────────────────────────────────────────────────────────────────────
# Security note: behind Caddy, X-Forwarded-For is set automatically.
# The per-IP rate limiter in app/core/ratelimit.py keys on request.client.host.
# Trust X-Forwarded-For ONLY behind this proxy you control (see runbook §XFF).
# ─────────────────────────────────────────────────────────────────────────────
