# GSSG Manager — environment variables
# Copy to .env (gitignored) and adjust per machine.

# Directory holding the SQLite DB, vault, and logs.
# Leave unset to default to ./data next to the project root.
# In production / network-share deployments, point this at the shared folder.
GSSG_DATA_DIR=

# Logging verbosity. One of: DEBUG, INFO, WARNING, ERROR.
GSSG_LOG_LEVEL=INFO

# 1 = dev mode (pretty logs, auto-reload hints, opens DevTools in pywebview).
# 0 = prod mode (JSON logs, DevTools off).
GSSG_DEV_MODE=1

# Backend port. 0 = probe a free port at startup.
# Use a fixed port (e.g. 8765) only for development against the Vite proxy.
GSSG_PORT=0

# ---------------------------------------------------------------------------
# LAN service settings (backend/serve.py — used by the NSSM GSSGManager
# service so the app is reachable from every office PC / phone).
# See docs/deploy-lan.md for the full runbook.
# ---------------------------------------------------------------------------

# Bind address. 0.0.0.0 = reachable from other PCs/phones on the office LAN.
# Leave at 127.0.0.1 for a loopback-only test.
# GSSG_HOST=0.0.0.0

# Fixed LAN port. Must be non-zero for the service (0 is the desktop probe).
# Firewall rule + bookmarks key off this — keep it stable.
# GSSG_PORT=8765
